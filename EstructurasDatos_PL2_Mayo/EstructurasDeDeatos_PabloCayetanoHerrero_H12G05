package ArbolBinarioDeBúsqueda_y_Grafo.Árbol;

import ArbolBinarioDeBúsqueda_y_Grafo.Lista.Lista;


public class ArbolBinarioDeBusqueda<E extends Comparable<E>> {

    private NodoABB<E> raiz; // La raíz es el primer nodo del árbol, del cuál salen los hijos (estos hisjos a su vez son raices de subárboles del árbol principal).
    private int size; // Se crea la variable tamaño para saber cuántos elementos se llevan y no tener que contarlos directamente.

    public ArbolBinarioDeBusqueda() { // Se crea el Constructor vacío del árbol, es decir, cuando todavía no tine ni siquiera un elemento, el nodo raíz.
        raiz = null; // No hay nodo raíz.
        size = 0; // No hay nada, y por tanto no tiene tamaño.
    }







//---------------------------------------------------- Añadir elemento / Modificar elemento / Vaciar el árbol -------------

    // Metodo add para añadir elementos al árbol.
    public void add(E elemento) {
        if (contiene(elemento)) { // Si el elemento ya está en el arbol no se puede duplicar.
            System.out.println("Elemento duplicado, no se inserta");
            return; // Nos salimos del metodo.
        }
        raiz = addRec(raiz, elemento); // Se usa un metodo para añadir el elemento en su respectivo lugar, lo que se calcula desde el nodo raíz.
        size += 1; // Aumenta en uno la cantidad total de elementos en el árbol.
    }


    private NodoABB<E> addRec(NodoABB<E> nodo, E elemento) { // Es un metodo para añadir el elemento en su respectivo lugar. Es privado porque afecta a otro metodo
        // (add), y no se necesita fuera de este.
        if (nodo == null) { // Si tras ir a drecha/izquierda se encuentra un nodo que esté vacío se coloca en esa posición el nuevo elemento.
            return new NodoABB<>(elemento);
        }if (elemento.compareTo(nodo.getDato()) < 0) { // Si el elemento es menor al del nodo ...
            nodo.setIzquierda(addRec(nodo.getIzquierda(), elemento)); // Se pasa al nodo hijo izquierdo del nodo con el que se ha comparado, y se repite la comparación
            // recursivamente hasta que se llega al primer caso (nodo == null).
        } else { // Si el elemento es mayor al del nodo ...
            nodo.setDerecha(addRec(nodo.getDerecha(), elemento)); // Se pasa al nodo hijo derecho del nodo con el que se ha comparado, y se repite la comparación
            // recursivamente hasta que se llega al primer caso (nodo == null).
        }
        return balancear(nodo); // Al acabar de añadir el elemento, se comprueba si hay desbalance y se balancea el árbol en caso positivo.
    }





    // Metodo para modificar un elemento que has metido.
    public void modificarElemento(E elementoAntiguo, E elementoNuevo) {
        if (!contiene(elementoAntiguo)) { // Se comprueba si el elemento que intentamos modificar está en el árbol.
            System.out.println("El elemento no existe en el árbol"); // Si no lo está se avisa de que no está.
            return; // Nos salimos.
        } if (elementoAntiguo.equals(elementoNuevo)) { // Si son iguales no se hace nada.
            return; // Nos salimos.
        } if (contiene(elementoNuevo)) { // Si el elemento ya está en el árbol, no se puede sustituir otro por ese.
            raiz = removeRec(raiz, elementoNuevo); // Se elimina el elemento por el que se va a sustituir el que queremos sustituir para que no haya elementos repetidos.
            size -= 1; // Se reduce el tamaño en uno.
        }
        raiz = removeRec(raiz, elementoAntiguo); // Se elimina el elemento que queremos sustituir.
        size -= 1; // Se reduce en uno la cantidad de elementos en el árbol. Esto se hace porque luego ad hace size += 1.
        add(elementoNuevo); // Se añade el elemento correcto.
    }



    public boolean contiene(E elemento) { // Es un metodo que mira a ver si un elemento está en el árbol o no.
        return contieneRec(raiz, elemento); // Se mira desde la raíz.
    }

    private boolean contieneRec(NodoABB<E> nodo, E elemento) {
        if (nodo == null) { return false; // Si se llega a un nodo vacío no se puede seguir, lo que quiere decir que el elemento no está.
        } if (nodo.getDato().equals(elemento)) { return true; // Si el nodo en el que se está es el elemento, quiere decir que está.
        }if (elemento.compareTo(nodo.getDato()) < 0) { // Si el elemento es menor que el del nodo, se va a la izquierda.
            return contieneRec(nodo.getIzquierda(), elemento);
        } else { // Si el elemento es mayor al del nodo, se va a la derecha.
            return contieneRec(nodo.getDerecha(), elemento);}
    }

    private NodoABB<E> removeRec(NodoABB<E> nodo, E elemento) { // Metodo para eliminar un elemento del árbol.
        if (nodo == null) { return null; // Si no existe, no hay nada que borrar.
        } if (elemento.compareTo(nodo.getDato()) < 0) { // Si el elemento es menor que el nodo, se va a la izquierda.
            nodo.setIzquierda(removeRec(nodo.getIzquierda(), elemento));
        } else if (elemento.compareTo(nodo.getDato()) > 0) { // Si el elemento es mayor que el nodo, se va a la derecha.
            nodo.setDerecha(removeRec(nodo.getDerecha(), elemento));
        } else { // Si no es mayor o menor, entonces es el número.
            // Caso 1: Nodo hoja.
            if (nodo.getIzquierda() == null && nodo.getDerecha() == null) {
                return null;} // Lo eliminamos y ya está.
            // Caso 2: Un solo hijo.
            if (nodo.getIzquierda() == null) { // No tiene hijo izquierdo.
                return nodo.getDerecha(); // Lo sustituimos por su hijo derecho.
            } if (nodo.getDerecha() == null) { // No tiene hijo derecho.
                return nodo.getIzquierda();} // Se sustituye por su hijo izquierdo.
            // Caso 2: Tiene los dos hijos.
            NodoABB<E> sucesor = minimo(nodo.getDerecha()); // Busca el menor elemento del árbol derecho (el de la izquierda de todos).
            nodo.setDato(sucesor.getDato()); // Se sustituye por ese elemento.
            nodo.setDerecha(removeRec(nodo.getDerecha(), sucesor.getDato())); // Se elimina el elmento que se ha pasado a sustituiar al que se ha eliminado para que no está duplicado.
        }
        return balancear(nodo); // Se balancea el árbol.
    }

    private NodoABB<E> minimo(NodoABB<E> nodo) { // Metodo que encuentra el menor valor de un subárbol.
        while (nodo.getIzquierda() != null) { // Mientras que el hijo izquierdo exista.
            nodo = nodo.getIzquierda(); // Ir por la izquierda.
        }
        return nodo; // Cuando el hijo izquierdo no existe, se retorna el elemento en ese nodo.
    }


    private NodoABB<E> balancear(NodoABB<E> nodo) { // Es el metodo para, tras colocar el nuevo elemento en su lugar, mire si el árbol está desequilibrado,
        // y si lo está, lo equilibra.

        int balance = alturaRec(nodo.getIzquierda()) - alturaRec(nodo.getDerecha()); // El balance se obtiene mirando recursivamente las alturas hasta llegar a todas los
        // alturas de los subárboles, y haciendo la diferencia entre estas.

        // Giro hacia la derecha.
        if (balance > 1) { // Si la profundidad es mayor en el subárbol de la izquierda, se gira hacia la derecha para balancear el árbol.

            if (alturaRec(nodo.getIzquierda().getIzquierda()) >= alturaRec(nodo.getIzquierda().getDerecha())) { // Si está orientado en sentido: nodo - H.izq. - H.izq.
                return rotacionDerecha(nodo); // Solo hace falta girar una vez porque están colocados: mayor - mediano - menor, y pasan a estar:
                // mediano - pequeño, mediano - mayor.
            } else { // Si está orientado: nodo - H.izq. - H.drch.
                nodo.setIzquierda(rotacionIzquierda(nodo.getIzquierda())); // Está colocado: mayor - menor - mediano. Tiene que pasar a: mayor - mediano - menor,
                // girándo hacia la izquierda.
                return rotacionDerecha(nodo); // Una vez está mayor - mediano - pequeño, se gira a la derecha para que esté: mediano - menor, y mediano - mayor.
            }
        }

        // Giro hacia la izquierda.
        if (balance < -1) { // Si la profundidad es mayor en el subárbol de la derecha, se gira hacia la izquierda para balancear el árbol.
            if (alturaRec(nodo.getDerecha().getDerecha()) >= alturaRec(nodo.getDerecha().getIzquierda())) { // Si está orientado en sentido: nodo - H.drch. - H.drch.
                return rotacionIzquierda(nodo); // Solo hace falta girarlo hacia la izquierda una vez.
            } else { // Si está orientado en sentido: nodo - H.drch. - H.izq.
                nodo.setDerecha(rotacionDerecha(nodo.getDerecha())); // Se gira hacia la derecha para que pase a estar en sentido: mayor - mediano - pequeño.
                return rotacionIzquierda(nodo); // Se gira hacia la izquierda para que pase a estar en sentido: mediano - menor, mediano - mayor.
            }
        }
        return nodo; // Se retorna el nodo.
    }

    private NodoABB<E> rotacionDerecha(NodoABB<E> t) { // Es el metodo para girar hacia la derecha y equilibrar el árbol.
        NodoABB<E> x = t.getIzquierda(); // Se toma el nodo hijo izquierdo de t.
        NodoABB<E> y = x.getDerecha(); // Se toma el nodo hijo derecho de x.
        x.setDerecha(t); // Ahora t, en vez de ser el nodo "padre" de x, pasa a ser el hijo derecho de x.
        t.setIzquierda(y); // Ahora y pasa a ser el nodo hijo izquierda de t.
        return x; // Se retorna x.
    }

    private NodoABB<E> rotacionIzquierda(NodoABB<E> t) { // Es el metodo para girar hacia la izquierda y equilibrar el árbol.
        NodoABB<E> y = t.getDerecha(); // Se toma el nodo hijo derecha de t.
        NodoABB<E> x = y.getIzquierda(); // Se toma el nodo hijo izquierda de y.
        y.setIzquierda(t); // Ahora t, en vez de ser el nodo "padre" de y, pasa a ser su nodo hijo izquierda.
        t.setDerecha(x); // Ahora x pasa a ser el nodo hijo derecha de t.
        return y; // Se retorna y.
    }






    public void vaciar() {
        raiz = null; // La raíz pasa a ser nula, lo que desconecta los dos subárboles, perdiéndolos, ya que todos los métodos parten desde la raíz.
        size = 0; // Como ya no hay elementos, la cantidad de elementos en el árbol es de cero.
    }








//-------------------------------------- Obtener la altura / Obtener grado / Elementos en el árbol-------------------------

    // Es el metodo para calcular la altura/profundidad del árbol.
    public int getAltura() {
        return alturaRec(raiz); // Se retorna la altura partiendo desde el nodo raíz. Se usa un metodo para ello.
    }

    private int alturaRec(NodoABB<E> nodo) { // Es el metodo recursivo que calcula la altura del árbol.
        if (nodo == null) { // Si el nodo en el que se está es nulo, no aumenta la altura.
            return 0; // Si no aumenta la altura, añade 0 a la altura y se va hacia atrás, dando la altura de esa rama.
        }
        int izq = alturaRec(nodo.getIzquierda()); // Se crea la variable interna izq para calcular la altura del subárbol del nodo hijo izquierdo del nodo en el que se esté.
        int drch = alturaRec(nodo.getDerecha()); // Se crea la variable interna drch para calcular la altura del subárbol del nodo hijo derecho del nodo en el que se esté.

        return 1 + Math.max(izq, drch); // Se retorna el nodo desde el que se ha ido a una rama (1) + la profundidad del subárbol desde ese nodo. Al ser recursivo y mirarse
        // desde la raíz, da la altura del árbol.
    }


// Metodo para obtener el grado del árbol.
    public int getGrado() {
        return getGradoRec(raiz); // Se calcula desde la raíz.
    }
    private int getGradoRec(NodoABB<E> nodo) {
        if (nodo == null) { return 0; // Si el nodo está vacío, hay que retornar cero.
        }
        int hijos = 0; // Se inicializa el contador en 0.
        if (nodo.getIzquierda() != null) hijos += 1; // Si el nodo hijo izquierdo existe, hay un hijo más.
        if (nodo.getDerecha() != null) hijos += 1; // Si el nodo hijo derecho existe, hay un hijo más.
        int gradoIzq = getGradoRec(nodo.getIzquierda()); // Se va hacia el subárbol izquierdo del árbol.
        int gradoDer = getGradoRec(nodo.getDerecha()); // Se va hacia el subárbol derecho del árbol.
        return Math.max(hijos, Math.max(gradoIzq, gradoDer)); // Se retorna el subárbol que mayor grado tenga.
    }



    public int getSize() { // Metodo para saber cuántos elementos hay en el árbol.
        return size; // Se retorna la variabe size, que ha sido modificada según se incorporaban/modificaban datos.
    }


    public boolean isEmpty() { // Es un metodo para saber si el árbol está vacío.
        return size == 0; // Si size es 0, retorna true, si size no es 0, retorna false, es decir, que no está vacío.
    }















//-------------------------------------------------------------- PreOrden / PostOrden / OrdenCentral ----------------------


    public Lista<E> getListaPreOrden() { // Los elementos salen en preorden.
        Lista<E> lista = new Lista<>(); // Se crea una lista vacía.
        preOrden(raiz, lista); // Se llena la lista en preorden desde la raíz.
        return lista; // Se imprime la lista.
    }

    private void preOrden(NodoABB<E> nodo, Lista<E> lista) {
        if (nodo != null) { // Si el nodo no es vacío. (Si lo es se sale del metodo).
            lista.add(nodo.getDato()); // Se añade el valor del nodo raíz.
            preOrden(nodo.getIzquierda(), lista); // Se recorre el subárbol izquierdo de manera recursiva.
            preOrden(nodo.getDerecha(), lista); // Al salir de la recursión se va al nodo "padre", y se va al nodo hijo derecho, recorriendo otra vez el subárbol
            // izquierdo si hay, si no lo hay, el derecho, si no lo hay, se va al nodo "abuelo", y va al nodo hijo derecho, que va al subárbol izquierdo, ...
        }
    }

    public Lista<E> getListaPostOrden() { // Los elementos salen en postorden.
        Lista<E> lista = new Lista<>(); // Se crea una lista vacía.
        postOrden(raiz, lista); // Se llena la lista en postorden desde la raíz.
        return lista; // Se imprime la lista.
    }

    private void postOrden(NodoABB<E> nodo, Lista<E> lista) {
        if (nodo != null) { // Si el nodo no es vacío. (Si lo es se sale del metodo).
            postOrden(nodo.getIzquierda(), lista); // Se recorre el  subárbol izquierdo de manera recursiva.
            postOrden(nodo.getDerecha(), lista); // Al salir de la recursión se va al nodo "padre", y se va al nodo hijo derecho, recorriendo otra vez el subárbol
            // izquierdo si hay, si no lo hay, el derecho, si no lo hay, se va al nodo "abuelo", y va al nodo hijo derecho, que va al subárbol izquierdo, ...
            lista.add(nodo.getDato()); // Se imprime el nodo hoja al que se haya llegado, e sale, y se imprime el que toque, y así sucesivamente.
        }
    }

    public Lista<E> OrdenCentral() { // Los elementos salen en OrdenCentral.
        Lista<E> lista = new Lista<>(); // Se crea una lista vacía.
        OrdenCentro(raiz, lista); // Se llena la lista en OrdenCentral.
        return lista; // Se retorna la lista.
    }

    private void OrdenCentro(NodoABB<E> nodo, Lista<E> lista) {
        if (nodo != null) { // Si el nodo no es vacío. (Si lo es se sale del metodo).
            OrdenCentro(nodo.getIzquierda(), lista); // Se recorre el  subárbol izquierdo de manera recursiva.
            lista.add(nodo.getDato()); // Se imprime el nodo al subir desde el nodo hijo izquierda, y después se va al nodo hijo derecho.
            OrdenCentro(nodo.getDerecha(), lista); // Al salir de la recursión se va al nodo "padre", y se va al nodo hijo derecho, recorriendo otra vez el subárbol
            // izquierdo si hay, si no lo hay, el derecho, si no lo hay, se va al nodo "abuelo", y va al nodo hijo derecho, que va al subárbol izquierdo, ...
        }
    }













//--------- Obtener elementos en un nivel / Camino a un elemento / Máximo y mínimo / Hojas y nodos intermedios ------------

    public Lista<E> getListaDatosNivel(int nivel) { // Es el metodo para ver qué valores hay en un mismo nivel del árbol.
        Lista<E> lista = new Lista<>(); // Se crea una lista vacía.
        nivelRec(raiz, 0, nivel, lista); // La lista se llena con los valores de los nodos que estén en el nivel indicado.
        return lista; // Se retorna la lista.
    }

    private void nivelRec(NodoABB<E> nodo, int actual, int buscado, Lista<E> lista) {
        if (nodo == null){ return; // Si el nodo está vacío, se sale del metodo.
        } if (actual == buscado) { // Si el nivel en el que se está es el nivel al que se quería llegar.
            lista.add(nodo.getDato()); // Se añade el elemento a la lista.
        } else { // Si no se está en el nivel que se quiere.
            nivelRec(nodo.getIzquierda(), actual + 1, buscado, lista); // Se busca en su nodo hijo izquierda.
            nivelRec(nodo.getDerecha(), actual + 1, buscado, lista); // Se busca en su nodo hijo derecho.
        }
    }


// Metodo para ver qué elementos hay en un nivel determinado.
    public int getNumeroNodosNivel(int nivel) {
        return contarNivelRec(raiz, 0, nivel); // Se busca desde la raíz hasta un nivel determinado.
    }
    private int contarNivelRec(NodoABB<E> nodo, int actual, int buscado) {
        if (nodo == null) { return 0; // Si el nodo es nulo, no se ha llegado al que se busca.
        }if (actual == buscado) return 1; // Si el que se busca es en el que está ese nodo, se retorna 1.
        return contarNivelRec(nodo.getIzquierda(), actual + 1, buscado) + contarNivelRec(nodo.getDerecha(), actual + 1, buscado); // Se suma la cantidad total de elementos esn ese nivel del árbol.
    }


// Metodo para sacar el nivel en el que se encuentra un elemento.
    public int getNivelElemento(E elemento) {
        return nivelRec(raiz, elemento, 0); // Se inicia desde la raíz, en el nivel cero.
    }
    private int nivelRec(NodoABB<E> nodo, E elemento, int nivel) {
        if (nodo == null) { return -1; // Si no hay nada más en el camino que te llevaría a ese elemento, no existe en el árbol.
        }if (nodo.getDato().equals(elemento)) { return nivel; // Si el elemento es el nodo en el que se está, se devuelve el nivel.
        }if (elemento.compareTo(nodo.getDato()) < 0) { // Si el elemento es menor, vamos hacia la izquierda.
            return nivelRec(nodo.getIzquierda(), elemento, nivel + 1);
        } else { // Si el elemento es menor, vamos hacia la derecha.
            return nivelRec(nodo.getDerecha(), elemento, nivel + 1);
        }
    }





    public Lista<E> getCamino(E elemento) { // Es un metodo que, al darle un elemento, busca el camino desde la raíz hasta ese elemento.
        Lista<E> lista = new Lista<>(); // Se crea una lista vacía.
        caminoRec(raiz, elemento, lista); // Se llama al metodo para recorrer el camino.
        return lista; // Se imprime la lista con los valores hasta el elemento que se quiere.
    }

    private boolean caminoRec(NodoABB<E> nodo, E elemento, Lista<E> lista) {
        if (nodo == null){ return false; // Si el nodo está vacío, es porque se ha intentado llegar, y no se ha podido porque nos hemos topado con un muro por donde
            // ya no se puede avanzar, es decir, no está el elemento que se busca.
        }
        lista.add(nodo.getDato()); // Si se pasa por un nodo, este es parte del camino, y por lo tanto hay que añadirlo a la lista.
        if (nodo.getDato().equals(elemento)) { // Si el elemento que se busca es en el que se está, entonces ya se ha acabado.
            return true; // Se retona true.
        } if (elemento.compareTo(nodo.getDato()) < 0) { // Si el elemento que se busca es menor que en el que se está.
            if (caminoRec(nodo.getIzquierda(), elemento, lista)){ return true;} // Se va hacia la izquierda. Si se ve que se retorna true es porque ha acabado llegando
            // hasta el elemento que se buscaba.
        } else { // Si el elmento que se busca es mayor que en el que se está.
            if (caminoRec(nodo.getDerecha(), elemento, lista)){ return true;} // Se va hacia la derecha. Si se ve que se retorna true es porque ha acabado llegando
            // hasta el elemento que se buscaba.
        }

        lista.remove(lista.getSize() - 1); // Se quita el elemento de la lista, porque ya se ha buscado ahí en su subárbol derecho e izquierdo, y no está el elemento.
        return false; // Se retorna false, porque no se ha encontrado el elemento, y este no formaría parte del camino hasta él.
    }



// Metodo para obtener el menor elemento del árbol.
    public E getMin() {
        if (raiz == null) { return null;} // Si la raíz no existe, se retorna null.
        NodoABB<E> actual = raiz; // Se crea un nodo actual que es la raíz.
        while (actual.getIzquierda() != null) { // Mientras que el nodo hijo izquierdo no sea nulo.
            actual = actual.getIzquierda(); // Se sigue por la izquierda.
        }
        return actual.getDato(); // Al salir del bucle se retorna el dato (el elemento mínimo del árbol).
    }

// Metodo para obtener el mayor elemento del árbol.
    public E getMax() {
        if (raiz == null) { return null;} // Si la raíz no existe, se retorna null.
        NodoABB<E> actual = raiz; // Se crea un nodo actual que es la raíz.
        while (actual.getDerecha() != null) { // Mientras que el nodo hijo derecho no sea nulo.
            actual = actual.getDerecha(); // Se sigue por la derecha.
        }
        return actual.getDato(); // Al salir del bucle se retorna el mayor eledel árbol.
    }



// Metodo para contar cuantas hojas tiene el árbol.
    public int contarHojas() {
        return contarHojasRec(raiz); // Se mira desde la raíz.
    }
    private int contarHojasRec(NodoABB<E> nodo) {
        if (nodo == null) { return 0; // Si el nodo no existe, se retorna cero.
        }if (nodo.getIzquierda() == null && nodo.getDerecha() == null) { // Si su hijo derecho e izquierdo no existe es porque es un nodo raíz.
            return 1; // Por ello se aumenta en uno la cantidad de ndods hoja.
        }
        return contarHojasRec(nodo.getIzquierda()) + contarHojasRec(nodo.getDerecha()); // Se mira en el subárbol derecho y en el subárbol izquierdo recursivamente.
    }



// Metodo para contar cuantos nodos internos tiene el árbol.
    public int contarNodosInternos() {
        return contarInternosRec(raiz); // Se mira desde la raíz.
    }
    private int contarInternosRec(NodoABB<E> nodo) {
        if (nodo == null) { return 0; // Si el nodo no existe, no es un nodo hoja.
        }if (nodo.getIzquierda() == null && nodo.getDerecha() == null) { // Si el nodo que se mira es un nodo hoja, no es interno.
            return 0;
        }
        return 1 + contarInternosRec(nodo.getIzquierda()) + contarInternosRec(nodo.getDerecha()); // Se miran el subárbol izquierdo y el subárbol derecho, y se le suma
        // uno (el nodo que se está mirando).
    }












//----------------------------------------------------------------- Subárboles --------------------------------------------

    public ArbolBinarioDeBusqueda<E> getSubArbolIzquierda() { // Es un metodo para utilizar el subárbol izquierdo de un árbol.
        ArbolBinarioDeBusqueda<E> sub = new ArbolBinarioDeBusqueda<>(); // Se crea un nuevo árbol de búsqueda.
        if (raiz != null) { // Si la raíz existe.
            sub.raiz = raiz.getIzquierda(); // La raíz pasa a ser el nodo hijo izquierda.
        }
        return sub; // Se retorna la nueva raíz.
    }

    public ArbolBinarioDeBusqueda<E> getSubArbolDerecha() { // Es un metodo para utilizar el subárbol derecho de un árbol.
        ArbolBinarioDeBusqueda<E> sub = new ArbolBinarioDeBusqueda<>(); // Se crea un nuevo árbol de búsqueda.
        if (raiz != null) { // Si la raíz existe.
            sub.raiz = raiz.getDerecha(); // La raíz pasa a ser el nodo hijo derecho.
        }
        return sub; // Se retorna la nueva raíz.
    }






//--------------------------------------- Homogéneo / Completo / Casi Completo --------------------------------------------

    // Metodo para ver si el árbol es homogéneo.
    public boolean isArbolHomogeneo() {
        if (raiz == null) { return true;} // Si la raíz no exista, todos los nodos tienen cero hijos.
        int grado = getGrado(); // El grado máximo del árbol.
        return esHomogeneo(raiz, grado); // Se mira desde la raíz.
    }

    private boolean esHomogeneo(NodoABB<E> nodo, int grado) {
        if (nodo == null) { return true;}
        int hijos = 0; // Se inicializa un contador.
        if (nodo.getIzquierda() != null) { hijos += 1; // Si tiene hijo izquierdo, ese nodo se suma un hijo.
        }if (nodo.getDerecha() != null) { hijos += 1;// Si tiene hijo derecho, ese nodo se suma un hijo.
        }if (hijos != grado && hijos != 0) { return false;} // Si la cantidad de hijos está entre el grado y cero, no es homogéneo.
        return esHomogeneo(nodo.getIzquierda(), grado)  && esHomogeneo(nodo.getDerecha(), grado); // Se llama a los subárboles para mirar sus nodos.
    }



// Metodo para ver si el árbol es completo.
    public boolean isArbolCompleto() {
        int altura = alturaRec(raiz); // La altura del árbol.
        return esCompleto(raiz, 1, altura);
    }

    private boolean esCompleto(NodoABB<E> nodo, int nivel, int altura) {
        if (nodo == null) { return true;
        }if (nodo.getIzquierda() == null && nodo.getDerecha() == null) { // Si el nodo es hoja.
            return nivel == altura; // Se compara con la altura del árbol para ver si conincide, y retorna true o false.
        }
        return esCompleto(nodo.getIzquierda(), nivel + 1, altura)  && esCompleto(nodo.getDerecha(), nivel + 1, altura);
        // Se miran los subárboles hasta que se acabe o el nivel de un nodo hoja es distinto de la altura.
    }



// Metodo para ver si el árbol el casi completo.
    public boolean isArbolCasiCompleto() {
        int size = getSize(); // Cantidad de elementos que conforman el árbol.
        return esCasiCompleto(raiz, 0, size);
    }

    private boolean esCasiCompleto(NodoABB<E> nodo, int indice, int size) {
        if (nodo == null) { return true;
        }if (indice >= size) { return false;} // Si el índice es mayor que el tamaño, está mal.
        return esCasiCompleto(nodo.getIzquierda(), 2 * indice + 1, size)  && esCasiCompleto(nodo.getDerecha(), 2 * indice + 2, size);
    }










//------------------------------------------------ Imprimir el árbol ------------------------------------------------------

    // Metodo para imprimir el árbol.
    public void imprimirArbol() {
        imprimirRec(raiz, "", true);
    }

    private void imprimirRec(NodoABB<E> nodo, String prefijo, boolean esDerecho) {
        if (nodo == null) { return; // Si ya no hay nodos, esa rama del árbol ha acabado de hacerse.
        }
        // Se imprime el subárbol derecho.
        if (nodo.getDerecha() != null) { // Si exi
            // ste un nodo hijo derecho del nodo.
            imprimirRec(nodo.getDerecha(), prefijo + (esDerecho ? "        " : " |      "), true);
            // El prefijo añade los espacios o las barras, (esDerecho ? hace que si viene de la derecha emprima los espacios, y
            // si no viene de la derecha (vienede la izquierda), se añade una columna. True marca a esDerecho que viene por la derecha,
            // es decir, que se añaden espacios.
        }
        // Imprime el nodo actual
        System.out.println(prefijo + (esDerecho ? " /-- " : " \\-- ") + nodo.getDato());
        // Si es derecho se añade "/--", y sino se añade "--\", y junto a ello el elemento.

        // Se imprime el subárbol izquierdo.
        if (nodo.getIzquierda() != null) { // Si existe.
            imprimirRec(nodo.getIzquierda(), prefijo + (esDerecho ? " |      " : "        "), false);
            // Como viene de la izquierda, esDerecho es false, y se ponen espacios.
        }
    }
}











