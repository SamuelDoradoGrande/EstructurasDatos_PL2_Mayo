package ArbolBinarioDeBúsqueda_y_Grafo.Grafo;

import ArbolBinarioDeBúsqueda_y_Grafo.Lista.Lista;
import ArbolBinarioDeBúsqueda_y_Grafo.Cola.Cola;
import java.io.*;
import java.io.FileNotFoundException;
import java.io.FileReader;
import java.io.IOException;

public class Grafo<E> {

    private Lista<Vertice<E>> vertices; // Lista de los vértices del grafo.
    private Lista<Arista<E>> aristas; // Lista de las aristas del grafo.



    // Getters de vértices y aristas.
    public Lista<Vertice<E>> getVertices() {
        return vertices;
    }
    public Lista<Arista<E>> getAristas() {
        return aristas;
    }




    //------------------------------ Vértices y aristas ---------------------------------
    public Grafo() { // Constructor del grafo vacío.
        vertices = new Lista<>();
        aristas = new Lista<>();
    }


    // Metodo para añadir un vértice al grafo.
    public void addVertice(E dato) {
        if (buscarVertice(dato) != null) { // Si el vértice ya existe, no lo añade.
            return; // Nos salimos.
        }
        vertices.add(new Vertice<>(dato)); // Si no está, lo añade a la lista de vértices.
    }


    // Metodo para añadir una arista dirigida al grafo.
    public void addArista(E origen, E destino, String relacion, double coste) {
        Vertice<E> vOrigen = buscarVertice(origen); // Busco el vértice de origen.
        Vertice<E> vDestino = buscarVertice(destino); // Busco el vértice de destino.
        if (vOrigen == null || vDestino == null) { // Si no existe el origen o el destino.
            System.out.println("No existe origen o destino");
            return; // Nos salimos.
        }
        Arista<E> nueva = new Arista<>(vOrigen, vDestino, relacion, coste); // Se crea la arista.
        aristas.add(nueva); // Se guarda en la lista de aristas.
        vOrigen.addArcoSalida(nueva); // Se añade a la lista de aristas que salen del origen.
    }




    // Metodo para buscar un vértice en el grafo.
    public Vertice<E> buscarVertice(E dato) {
        for (int i = 0; i < vertices.getSize(); i += 1) { // Se recorren los vértices.
            if (vertices.get(i).getDato().equals(dato)) { // Si se encuentra.
                return vertices.get(i); // Se retorna el vértice que se buscaba.
            }
        }
        return null; // Si no se encuentra, se retorna nulo, es decir, que no está.
    }



    // Metodo para ver si hay un detrminado vértice en el grafo.
    public boolean contieneVertice(E dato) {
        return buscarVertice(dato) != null;  // Si al buscar el dato este está, se retorna el dato, que es distinto de null
        // y se retorna true.
    }




    // Metodo para añadir tripletes.
    public void addTripleta(E sujeto, String predicado, E objeto) {
        addArista(sujeto, objeto, predicado, 1.0); // Se crea una arista.
    }

    // Metodo para imprimir los tripletes que hay en aristas.
    public void imprimirTripletas() {
        for (int i = 0; i < aristas.getSize(); i += 1) { // Se recorren las aristas.
            Arista<E> a = aristas.get(i); // Se saca la arista actual.
            System.out.println( a.getOrigen().getDato() + " -- " + a.getRelacion() + " --> " + a.getDestino().getDato());
            // Se imprime el triplete.
        }
    }



//--------------------------------------------- BFS -------------------------------

    // Metodo para hacer el BFS desde un "origen" determinado.
    public Lista<E> BFS(E origenDato) {
        Vertice<E> origen = buscarVertice(origenDato); // Busca el vértice origen.
        if (origen == null) { // Si no existe el origen.
            System.out.println("No existe el original");
            return null; // No se puede hacer nada.
        }
        Lista<Vertice<E>> visitados = new Lista<>(); // Se guardan los vértices visitados.
        Cola<Vertice<E>> cola = new Cola<>(); // Cola de BFS.
        Lista<E> recorrido = new Lista<>(); // Se guardan en orden los vértices por los que se ha pasado.
        cola.enqueue(origen); // Se empieza desde "origen".
        visitados.add(origen); // Se añade a la lista de los vértices visitados el origen.
        while (!cola.isEmpty()) { // Mientras que la cola no esté vacía.
            Vertice<E> actual = cola.dequeue(); // Saca el siguiente elemento.
            recorrido.add(actual.getDato()); // Se marca como que ese es el recorrido.
            for (int i = 0; i < actual.getArcosSalida().getSize(); i += 1) { // Recorre la lista de los vértices vecinos del vértice.
                Vertice<E> vecino = actual.getArcosSalida().get(i).getDestino(); // Se coje el vértice.
                if (!visitados.contains(vecino)) { // Si no está el vértice en los visitados.
                    visitados.add(vecino); // Se marca como visitado.
                    cola.enqueue(vecino); // Se guarda en la cola.
                }
            }
        }
        return recorrido; // Se retorna el recorrido.
    }





//------------------------------------- Dijkstra -----------------------------

    // Metodo para hallar el camino mínimo entre dos vértices determinados con Dijkstra.
    public Lista<E> getCaminoMinimo(E origenDato, E destinoDato) {
        Vertice<E> origen = buscarVertice(origenDato); // Se busca el vértice origen para empezar desde ahí.
        Vertice<E> destino = buscarVertice(destinoDato); // Se busca el vértice destino para llegar ahí.
        if (origen == null || destino == null) { // Si no existe el origen o el destino.
            return new Lista<>(); // Nos salimos y se retorna una lista vacía.
        }
        Lista<Vertice<E>> pendientes = new Lista<>(); // Son los vértices por los que no se ha pasado.
        Lista<Vertice<E>> visitados = new Lista<>();  // Son los vértices por los que se ha pasado.
        Lista<Double> distancias = new Lista<>(); // Distancia mínima actual desde el origen.
        Lista<Vertice<E>> anteriores = new Lista<>(); // Se guarda cuál es el nodo anterior a cada vértice que se ha llegado.
        inicializarDijkstra(origen, pendientes, distancias, anteriores);
        while (!pendientes.isEmpty()) { // Mientras que todavía falten vértices por los que pasar.
            Vertice<E> actual = extraerVerticeMenorDistancia(pendientes, distancias); // Se elige el que esté más cerca del actual.
            visitados.add(actual); // El que se ha visitado se añade a la lista de vértices añadidos.
            reducirAristas(actual, pendientes, visitados, distancias, anteriores); // Se busca un camino mejor.
        }
        return reconstruirCamino(origen, destino, anteriores); // Te dice el camino desde el origen al destino.
    }



    // Metodo que prepara las estructuras.  antes de hacer Dijkstra.
    private void inicializarDijkstra(Vertice<E> origen, Lista<Vertice<E>> pendientes, Lista<Double> distancias, Lista<Vertice<E>> anteriores) {
        for (int i = 0; i < vertices.getSize(); i += 1) { // Se recorren los vértices del grafo.
            pendientes.add(vertices.get(i)); // Se añade el vértice en el que se esté a pendientes.
            if (vertices.get(i).equals(origen)) { // Si el vértice es el origen.
                distancias.add(0.0); // La distancia al origen es cero.
            } else {
                distancias.add(Double.MAX_VALUE); // El resto inicia a una distancia "infinita".
            }
            anteriores.add(null); // Todavía no hay nada anterior.
        }
    }



    // Metodo para ver cuál es el vértice con el que conecta el último vértice con la menor distancia.
    private Vertice<E> extraerVerticeMenorDistancia(Lista<Vertice<E>> pendientes, Lista<Double> distancias) {
        Vertice<E> mejor = pendientes.get(0); // Suponemos que el primero es el mejor.
        for (int i = 1; i < pendientes.getSize(); i += 1) { // Se miran los vértices.
            if (getDistancia(pendientes.get(i), distancias) < getDistancia(mejor, distancias)) { // Si la distancia es menor, se cambia como mejor el más corto.
                mejor = pendientes.get(i); // Toma el elemento i de pendientes.
            }
        }
        pendientes.remove(pendientes.index(mejor)); // Elimina el elemento en i.
        return mejor; // Se retorna el elemento que menos distancia tiene con el vértice del que sale la arista.
    }



    // Metodo para ver si pasar por el vértice actual mejora el camino.
    private void reducirAristas(Vertice<E> actual, Lista<Vertice<E>> pendientes, Lista<Vertice<E>> visitados, Lista<Double> distancias, Lista<Vertice<E>> anteriores) {
        for (int i = 0; i < actual.getArcosSalida().getSize(); i += 1) { // Se recorren las aristas desde el vértice.
            Arista<E> arco = actual.getArcosSalida().get(i); // Se guarda la arista en la que se está.
            Vertice<E> vecino = arco.getDestino(); // Se ve el vértice al que llega la arista.
            if (visitados.contains(vecino)) { // Si ya se ha visitado.
                continue; // Se pasa de él.
            }
            double nuevaDistancia = getDistancia(actual, distancias) + arco.getCoste(); // Se calcula la distancia pasando por el vértice actual.
            if (nuevaDistancia < getDistancia(vecino, distancias)) { // Si la distancia es menor.
                setDistancia(vecino, nuevaDistancia, distancias); // Se modifica la distancia.
                setAnterior(vecino, actual, anteriores); // Se modifica el camino.
            }
        }
    }


    // Metodo que reconstruye el camino mínimo.
    private Lista<E> reconstruirCamino(Vertice<E> origen, Vertice<E> destino, Lista<Vertice<E>> anteriores) {
        Lista<E> caminoInvertido = new Lista<>(); // Se crea la lista para hacer el camnino desde el destino hasta el origen.
        Vertice<E> actual = destino; // Se inicia desde el vértice de destino.
        while (actual != null) { // Se hace un bucle.
            caminoInvertido.add(actual.getDato()); // Se añade el vértice.
            if (actual.equals(origen)) { // Si el actual es el vértice origen.
                break; // Se acaba.
            }
            actual = getAnterior(actual, anteriores); // Va al vértice anterior.
        }
        return invertirLista(caminoInvertido); // Se retorna el camino al revés.
    }



    // Metodo para saber la distancia a ese vértice.
    private double getDistancia(Vertice<E> vertice, Lista<Double> distancias) {
        int indice = vertices.index(vertice); // Se busca la posición del vértice.
        return distancias.get(indice); // Se devuelve la distancia que está en ese índice.
    }
    // Metodo para cambiar la distancia a un vértices.
    private void setDistancia(Vertice<E> vertice, double distancia, Lista<Double> distancias) {
        int indice = vertices.index(vertice); // Se busca la posición del vértice.
        distancias.set(indice, distancia); // Se cambia la distancia.
    }



    // Metodo para saber el anterior vértice en el camino.
    private Vertice<E> getAnterior(Vertice<E> vertice, Lista<Vertice<E>> anteriores) {
        int indice = vertices.index(vertice); // Se busca la posición del vértice.
        return anteriores.get(indice); // Devuelve el vértice anterior.
    }
    // Metodo para guardar el vértice anterior al que se está en un momento determinado.
    private void setAnterior(Vertice<E> vertice, Vertice<E> anterior, Lista<Vertice<E>> anteriores) {
        int indice = vertices.index(vertice); // Se busca la posición del vértice.
        anteriores.set(indice, anterior); // Se guarda el vértice en esa posición.
    }



    // Metodo para darle la vuelta a una lista.
    private Lista<E> invertirLista(Lista<E> original) {
        Lista<E> invertida = new Lista<>(); // Se crea la lista.
        for (int i = original.getSize() - 1; i >= 0; i -= 1) { // Se recorre la lista desde el último elemento.
            invertida.add(original.get(i)); // Se añade a la lista.
        }
        return invertida; // Se devuelve la lista.
    }




