package ArbolBinarioDeBúsqueda_y_Grafo.Lista;

public class Lista<E> {


    private NodoLista<E> cabeza; // Es el primer elemento de la lista.
    private int size; // Una variable para ver la cantidad de elementos que hay en la lista.



    public Lista() { // Constructor vacío de la lista.
        cabeza = null;
        size = 0;
    }



    public void add(E elemento) { // Metodo para añadir elementos a la lista.
        NodoLista<E> nueva = new NodoLista<E>(elemento); // Se crea la lista vacía.

        if (cabeza == null) { // Si la cabeza de la lista está vacía, se añade el elemento en la cabeza.
            cabeza = nueva;
        }
        else { // Si ya hay una cabeza.
            NodoLista<E> actual = cabeza; // Se crea un nodo actual para recorrer la lista y poder añadirlo.

            while (actual.getSiguienteelemento() != null) { // Se pasa al siguiente elemento mientras que el siguiente elemento exista.
                actual = actual.getSiguienteelemento(); // El actual pasa a ser el siguiente elemento.
            }
            actual.setSiguienteelemento(nueva); // Al acabar el bucle, ya no hay nada después, y ahí es donde se inserta el nuevo elemento.
        }
        size += 1; // La lista aumenta en uno.
    }




    public E remove(int posicion) { // Metodo para eliminar un elemento de una posición determinada.
        if (posicion < 0 || posicion >= size) { // Si la posición es negativa o mayor al tamaño de la lista, no existe tal elemento.
            System.out.println("No se puede eliminar el elemento de la posición requerida");
            return null; // Nos salimos del metodo.

        }
        NodoLista<E> eliminado; // Se crea un nodo para asignar ese elemento como el que se va a eliminar.

        if(posicion == 0) { // Si la posición es cero, el elemento a eliminar es la cabeza.
            eliminado = cabeza;
            cabeza = cabeza.getSiguienteelemento(); // La cabeza pasa a ser el siguiente elemento.
        }
        else { // Si la posición no es cero.
            NodoLista<E> anterior = cabeza; // Se crea un nodo para marcar el anterior elemento al que hay que eliminar.
            for (int i = 0; i < posicion-1; i = i+1) { // Para todos los elementos hasta que i sea la posicion donde está el elemento a eliminar.
                anterior = anterior.getSiguienteelemento(); // El anterior elemento pasa a ser el siguiente.
            }
            eliminado = anterior.getSiguienteelemento(); // El eliminado pasa a ser el siguiente elemento del anterior del que se va a eliminar.
            anterior.setSiguienteelemento(eliminado.getSiguienteelemento()); // Se enlazan el anterior elemento y el posterior elemento al elemento eliminado.
        }

        size -= 1; // Se reduce en uno el tamaño de la lista.
        return eliminado.getDato(); // Se retorna el dato eliminado.
    }



    public E get(int posicion) { // Metodo para ver qué elemento hay en una posición determinada.
        if (posicion < 0 || posicion >= size) { // Si la posición es negativa o mayor que el tamaño de la lista, no existe.
            System.out.println("No hay dato que imprimir, ya que no está en la lista");
            return null; // Nos salimos del metodo.
        }

        NodoLista<E> actual = cabeza; // Se asigna la cabeza al nodo actual.
        for (int i = 0; i < posicion; i = i+1) { // Para todos los elementos menores que el de la posición.
            actual = actual.getSiguienteelemento(); // Se avanza de uno en uno.
        }
        return actual.getDato(); // Se retorna el dato del elmento en esa posición.
    }



    // Metodo para ver si un elemento está en la lista.
    public boolean contains(E elemento) {
        NodoLista<E> actual = cabeza; // El nodo "actual" está en la cabeza.
        while (actual != null) { // Mientras que el actual exista.
            if (actual.getDato().equals(elemento)) { // Si actual es el elemento que se buesca.
                return true; // Se retorna true.
            }
            actual = actual.getSiguienteelemento(); // Si no es el elemento, se pasa al siguiente elemento de la lista.
        }
        return false; // Si no está el elemento retornamos false.
    }




    // Es un metodo para saber la posición de un elemento.
    public int index(E elemento) {
        NodoLista<E> actual = cabeza; // Se coloca el nodo actual en la cabeza.
        int indice = 0; // El índice de la cabeza es cero.
        while (actual != null) { // Mientras que actual exista.
            if (actual.getDato().equals(elemento)) { // Si actual es el dato en el que se está.
                return indice; // Se retorna su índice.
            }
            actual = actual.getSiguienteelemento(); // Si no lo es, se pasa al siguiente elemento de la lista.
            indice += 1; // Al avanzar en uno, el índice es uno mayor.
        }
        return -1; // Si no está se retorna menos uno.
    }




    // Metodo para cambiar el elmento en una posición determinada.
    public void set(int posicion, E elemento) {
        if (posicion < 0 || posicion >= size) { // Si la posición es negativa o mayor a la cantidad de elementos en la lista.
            System.out.println("Posición inválida");
            return; // Nos salimos.
        }
        NodoLista<E> actual = cabeza; // Se coloca actual en la cabeza.
        for (int i = 0; i < posicion; i += 1) { // Para todos los elementos en la lista hasta posición.
            actual = actual.getSiguienteelemento(); // El actual pasa a ser el siguiente elemento.
        }
        actual.setDato(elemento); // Cuando se llegue al elemento, este se cambia.
    }




    public int getSize() {
        return size;
    } // Se retorna el tamaño de la lista.



    public boolean isEmpty() {
        return size == 0;
    } // Si size es cero, se retorna true (true a está vacío), si no es cero, se retorna false (false a está vacío).



    // Metodo para vaciar la lista.
    public void clear() {
        cabeza = null;
        size = 0;
    }




    @Override
    public String toString() {
        String resultado = "["; // Se imprime el inicio del corchete.
        NodoLista<E> actual = cabeza; // El actual se coloca en la cabeza.
        while (actual != null) { // Hasta que actual no exista.
            resultado += actual.getDato(); // Se añade actual al resultado.
            actual = actual.getSiguienteelemento(); // Actual avanza.
            if (actual != null) { // Si actual existe.
                resultado += ", "; // Se para del anterior elemento con una coma.
            }
        }
        resultado += "]"; // Al acabar se cierra el corchete.
        return resultado; // Se retorna el String con los elementos de la lista.
    }
}


