package ArbolBinarioDeBúsqueda_y_Grafo.Árbol;

public class NodoABB<E extends Comparable<E>> {

    private E dato;
    private NodoABB<E> izquierda; // Se crea el nodo para el hijo de la izquierda (valor menor) con respecto un nodo determinado.
    private NodoABB<E> derecha; // Se crea el nodo para el hijo de la derecha (valor mayor) con respecto un nodo determinado.

    public NodoABB(E dato) { // Constructor del Nodo.
        this.dato = dato;
        this.izquierda = null;
        this.derecha = null;
    }

    // Getter y setter del atributo dato.
    public E getDato() { return dato;}
    public void setDato(E dato) { this.dato = dato;}

    // Getter y setter del atributo del nodo hijo izquierdo de un nodo.
    public NodoABB<E> getIzquierda() { return izquierda;}
    public void setIzquierda(NodoABB<E> izquierda) { this.izquierda = izquierda;}

    // Getter y setter del atributo del nodo hijo derecho de un nodo.
    public NodoABB<E> getDerecha() { return derecha;}
    public void setDerecha(NodoABB<E> derecha) { this.derecha = derecha;}
}








