    public void cargarDesdeJSON(String rutaArchivo) {
        try (BufferedReader br = new BufferedReader(new FileReader(rutaArchivo))) {
            // Se abre el archivo para leerlo y se lee.
            StringBuilder sb = new StringBuilder(); // Se pone lo que haya en el archivo.
            String linea; // Línea para guardar lo que se lee.
            while ((linea = br.readLine()) != null) { // Se lee el archivo línea por línea.
                sb.append(linea); // Se añade cada línea.
            }
            procesarJSON(sb.toString()); // Pasa el sb a texto para poder leelo.
        } catch (FileNotFoundException e) { // Si no existe se captura el error.
            System.out.println("El fichero no existe.");
        } catch (IOException e) { // Se capturan los errores de entrada/salida del archivo.
            System.out.println("Error leyendo archivo.");
        }
    }

    private void procesarJSON(String json) {
        String[] partes = json.split("\\{"); // Se separa el JSON cuando se encuentra un "{".
        for (int i = 0; i < partes.length; i += 1) { // Recorre el JSON.
            String parte = partes[i]; // Guarda la parte que se haya separado.
            if (parte.contains("\"s\"")) { // Si es un triplete.
                String sujeto = extraer(parte, "\"s\""); // Se saca el sujeto.
                String predicado = extraer(parte, "\"p\""); // Se saca la relación.
                String objeto = extraer(parte, "\"o\""); // Se saca el objeto.
                buscarOVertice(sujeto); // Se busca en el grafo si existe.
                buscarOVertice(objeto); // Se busca en el grafo si existe.
                addArista((E) sujeto, (E) objeto, predicado, 1.0); // Se añade la arista al grafo.
            }
        }
    }





