    // Metodo para obtener el árbol de expansión mínima con Kruskal.
    public Grafo<E> KRUSKAL() {
        Grafo<E> mst = new Grafo<>(); // Se crea un grafo.
        Lista<Arista<E>> ordenadas = copiarAristasSinDuplicados(); // Aristas ordenadas.
        ordenarAristasPorPeso(ordenadas); // Se ordenan las aristas por peso.
        Lista<Vertice<E>> representantes = new Lista<>(); // Se crea la Union-Find.
        for (int i = 0; i < vertices.getSize(); i += 1) { // Se recorren los vértices.
            representantes.add(vertices.get(i)); //
            mst.addVertice(vertices.get(i).getDato()); // Se añade el vértice al grafo.
        }
        for (int i = 0; i < ordenadas.getSize() && cantidadConjuntos(representantes) > 1; i += 1) { // Se recorren las aristas.
            Arista<E> arista = ordenadas.get(i); // Se guarda la arista.
            Vertice<E> u = arista.getOrigen(); // Se saca el origen.
            Vertice<E> v = arista.getDestino(); // Se saca el destino.
            if (findUF(u, representantes) != findUF(v, representantes)) { // Si son de conjuntos distintos no hacen un ciclo.
                mst.addArista(u.getDato(), v.getDato(), arista.getRelacion(), arista.getCoste()); // Se añade la arista al grafo.
                unionUF(u, v, representantes); // Se unen los conjuntos.
            }
        }
        return mst; // Se devuelve el grafo.
    }




    // Metodo para copiar aristas evitando duplicados inversos.
    private Lista<Arista<E>> copiarAristasSinDuplicados() {
        Lista<Arista<E>> resultado = new Lista<>(); // Se crea una lista.
        for (int i = 0; i < aristas.getSize(); i += 1) { // Se recorren las aristas.
            Arista<E> actual = aristas.get(i); // Se guarda la arista.
            boolean redundante = false; // Si está duplicada se marca.
            for (int j = 0; j < resultado.getSize(); j += 1) { // La compara con las que están en resultado.
                Arista<E> guardada = resultado.get(j); //Se guarda la arista.
                boolean mismaConexion = actual.getOrigen().equals(guardada.getDestino()) && actual.getDestino().equals(guardada.getOrigen()); // Se comprueba si es la conexión a la inversa.
                boolean mismoPeso = actual.getCoste() == guardada.getCoste(); // Se mira si tienen el mismo peso.
                if (mismaConexion && mismoPeso) { // Si son la misma pero inversa.
                    redundante = true; // Se marca como redundante.
                    break; // Nos salimos.
                }
            }
            if (!redundante) { // Si no es redundante, no estaba guardada.
                resultado.add(actual); // Se añade a la lista.
            }
        }
        return resultado; // Se retorna la lista.
    }



    // Metodo para ordenar aristas por peso ascendente.
    private void ordenarAristasPorPeso(Lista<Arista<E>> lista) {
        for (int i = 0; i < lista.getSize() - 1; i += 1) { // Se ordenan.
            for (int j = i + 1; j < lista.getSize(); j += 1) { // Se comparan.
                if (lista.get(j).getCoste() < lista.get(i).getCoste()) { // Si se ncuentra una arista menor.
                    Arista<E> temp = lista.get(i); // Se cambia la posición.
                    lista.set(i, lista.get(j)); // ""                  "".
                    lista.set(j, temp); // ""                           "".
                }
            }
        }
    }


    // Metodo de encontrar de Union-Find.
    private Vertice<E> findUF(Vertice<E> vertice, Lista<Vertice<E>> representantes) {
        int indice = vertices.index(vertice); // Se mira el índice del vértice.
        while (!representantes.get(indice).equals(vertices.get(indice))) { // Mientras que no sea el representante.
            indice = vertices.index(representantes.get(indice)); // Se sube.
        }
        return representantes.get(indice); // Se retorna el representante.
    }


    // Metodo de unir de Union-Find.
    private void unionUF(Vertice<E> a, Vertice<E> b, Lista<Vertice<E>> representantes) {
        Vertice<E> repA = findUF(a, representantes); // Se toma el representante.
        Vertice<E> repB = findUF(b, representantes); // Se toma el otro representante.
        int indiceRepB = vertices.index(repB); // Se mira el índice de B.
        representantes.set(indiceRepB, repA); // B se dirige al representante de A.
    }


    // Metodo para contar cuántos conjuntos disjuntos hay en Union-Find.
    private int cantidadConjuntos(Lista<Vertice<E>> representantes) {
        Lista<Vertice<E>> distintos = new Lista<>(); // Lista de los representantes.
        for (int i = 0; i < representantes.getSize(); i += 1) { // Se recorren los vértices.
            Vertice<E> rep = findUF(vertices.get(i), representantes); // Se saca el representante.
            if (!distintos.contains(rep)) { // Si no estaba contado.
                distintos.add(rep); // Se añade.
            }
        }
        return distintos.getSize(); // Se retorna el número de conjuntos.
    }



//----------------------- Imprimir el grafo -----------------------------------------------------

    // Metodo para imprimir el grafo
    public void imprimirGrafo() {
        if (vertices.isEmpty()) { // Si no hay vértices.
            System.out.println("El grafo está vacío.");
            return; // Nos salimos.
        }
        for (int i = 0; i < vertices.getSize(); i += 1) { // Se recorren todos los vértices.
            Vertice<E> vertice = vertices.get(i); // Se guarda el vértice actual.
            System.out.println(vertice.getDato() + ":"); // Se imprime el vértice.
            if (vertice.getArcosSalida().isEmpty()) { // Si no tiene aristas que salgan del vértice.
                System.out.println("   (Sin aristas)");
                continue; // Se pasa al siguiente vértice.
            }
            for (int j = 0; j < vertice.getArcosSalida().getSize(); j += 1) { // Se recorren las aristas.
                Arista<E> arista = vertice.getArcosSalida().get(j); // Se guarda la arista actual.
                System.out.println("   |--[" + arista.getRelacion() + ", coste=" + arista.getCoste() + "]--> " + arista.getDestino().getDato());
            }
        }
    }



//-------------------------------- Uso general -------------------------------

    // Metodo que busca un vértice, y si no existe, lo crea.
    private Vertice<E> buscarOVertice(String dato) {
        for (int i = 0; i < vertices.getSize(); i += 1) { // Se recorren los vértices del grafo.
            Vertice<E> v = vertices.get(i); // Se guarda el vértice.
            if (v.getDato().toString().equals(dato)) { // Se mira si el dato es el que queremos.
                return v; // Si es ese, se retorna.
            }
        }
        Vertice<E> nuevo = new Vertice<>((E) dato); // Si no está, se crea.
        vertices.add(nuevo); // Se añade.
        return nuevo; // Se retorna el vértice.
    }


    // Se saca un valor de un texto por una clave.
    private String extraer(String texto, String clave) {
        int ini = texto.indexOf(clave); // Se busca donde aparece "clave" en el texto.
        if (ini == -1) return ""; // Si no se ha encontrado "clave" nos salimos.
        ini = texto.indexOf(":", ini); // Desde "clave" se buscan ":".
        int fin = texto.indexOf("\"", ini + 2); // Se buscan las comillas.
        return texto.substring(ini + 2, fin);// Se devuelve l texto.
    }




    // Metodo para obtener todos los nodos de un tipo determinado según el prefijo.
    public Lista<E> getNodosPorPrefijo(String prefijo) {
        Lista<E> resultado = new Lista<>(); // Se crea la lista.
        for (int i = 0; i < vertices.getSize(); i += 1) { // Se recorren los vértices.
            E dato = vertices.get(i).getDato(); // Se guarda el dato.
            if (dato.toString().startsWith(prefijo)) { // Si tiene el prefijo.
                resultado.add(dato); // Se añade a la lista.
            }
        }
        return resultado; // Se devuelve la lista.
    }

}







