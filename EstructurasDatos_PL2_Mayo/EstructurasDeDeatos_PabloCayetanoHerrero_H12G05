    // Metodo para obtener el árbol de expansión mínima con Prim.
    public Grafo<E> PRIM(E origenDato) {
        Vertice<E> origen = buscarVertice(origenDato); // Se busca el origen.
        if (origen == null) { // Si no existe.
            return null; // Nos salimos.
        }
        Grafo<E> mst = new Grafo<>(); // Grafo resultado.
        Lista<Vertice<E>> visitados = new Lista<>(); // Vértices ya incluidos en el MST.
        Lista<Arista<E>> heap = new Lista<>(); // Lista de aristas candidatas.
        visitados.add(origen); // Se marca el origen como visitado.
        mst.addVertice(origen.getDato()); // Se añade al MST.
        for (int i = 0; i < origen.getArcosSalida().getSize(); i += 1) { // Se recorren las aristas.
            heap.add(origen.getArcosSalida().get(i)); // Se añaden.
        }
        while (!heap.isEmpty()) { // Mientras haya aristas candidatas.
            Arista<E> mejor = extraerAristaMenorPeso(heap); // Se escoge la de menor peso.
            Vertice<E> destino = mejor.getDestino(); // Se mira su destino.
            if (!visitados.contains(destino)) { // Si el destino no está en el MST.
                visitados.add(destino); // Se marca como visitado.
                mst.addVertice(destino.getDato()); // Se añade destino.
                mst.addArista(mejor.getOrigen().getDato(), destino.getDato(), mejor.getRelacion(), mejor.getCoste());
                for (int i = 0; i < destino.getArcosSalida().getSize(); i += 1) { // Se añaden nuevas aristas candidatas.
                    Arista<E> nueva = destino.getArcosSalida().get(i);
                    if (!visitados.contains(nueva.getDestino())) { // Solo si van a vértices no visitados.
                        heap.add(nueva); // Se añaden.
                    }
                }
            }
        }
        return mst; // Se devuelve el grafo. .
    }



    // Metodo para buscar la arista de menor peso de una lista.
    private Arista<E> extraerAristaMenorPeso(Lista<Arista<E>> aristas) {
        Arista<E> mejor = aristas.get(0); // Se toma la primera.
        for (int i = 1; i < aristas.getSize(); i += 1) { // Se busca la mejor.
            if (aristas.get(i).getCoste() < mejor.getCoste()) { // Si tiene menor coste.
                mejor = aristas.get(i); // Pasa a ser la mejor.
            }
        }
        aristas.remove(aristas.index(mejor)); // Se elimina de la lista.
        return mejor; // Se devuelve.
    }



    // Metodo para convertir el grafo en no dirigido añadiendo las aristas inversas.
    private void hacerNoDirigido() {
        Lista<Arista<E>> nuevasAristas = new Lista<>(); // Se crea una lista.
        for (int i = 0; i < aristas.getSize(); i += 1) { // Se recorren todas las aristas.
            Arista<E> actual = aristas.get(i); // Se guarda la arista actual.
            E origen = actual.getOrigen().getDato();
            E destino = actual.getDestino().getDato();
            if (!existeArista(destino, origen)) { // Si no existe la inversa.
                nuevasAristas.add(new Arista<>(buscarVertice(destino), buscarVertice(origen), actual.getRelacion(), actual.getCoste())); // Se crea.
            }
        }
        for (int i = 0; i < nuevasAristas.getSize(); i += 1) { // Se añaden las nuevas aristas.
            Arista<E> nueva = nuevasAristas.get(i);
            aristas.add(nueva);
            nueva.getOrigen().addArcoSalida(nueva);
        }
    }


    // Metodo para ver si existe una arista entre dos vértices.
    private boolean existeArista(E origenDato, E destinoDato) {
        Vertice<E> origen = buscarVertice(origenDato); // Se busca el origen.
