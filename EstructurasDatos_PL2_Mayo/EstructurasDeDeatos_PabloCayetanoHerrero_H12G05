    // Metodo para ver si el grafo tiene ciclos.
    public boolean tieneCiclos() {
        Lista<Vertice<E>> visitados = new Lista<>(); // Vértices ya visitados. .
        Lista<Vertice<E>> enRecursion = new Lista<>(); // Vértices en la rama actual del DFS.
        for (int i = 0; i < vertices.getSize(); i += 1) { // Se recorren los vértices.
            Vertice<E> vertice = vertices.get(i); // Se guarda el vértice actual.
            if (!visitados.contains(vertice)) { // Si aún no se ha visitado.
                if (TieneCiclo(vertice, visitados, enRecursion)) { // Si se detecta que hay un ciclo.
                    return true; // El grafo tiene ciclos.
                }
            }
        }
        return false; // Si no se encontró ninguno se retorna false.
    }


    // Metodo auxiliar para detectar ciclos con DFS.
    private boolean TieneCiclo(Vertice<E> actual, Lista<Vertice<E>> visitados, Lista<Vertice<E>> enRecursion) {
        visitados.add(actual); // Se marca como visitado.
        enRecursion.add(actual); // Se añade a la rama actual.
        for (int i = 0; i < actual.getArcosSalida().getSize(); i += 1) { // Se recorren las aristas salientes.
            Vertice<E> vecino = actual.getArcosSalida().get(i).getDestino(); // Se obtiene el vecino.
            if (!visitados.contains(vecino)) { // Si no se ha visitado todavía.
                if (TieneCiclo(vecino, visitados, enRecursion)) { // Si hay ciclo en profundidad.
                    return true; // Se retorna true.
                }
            }
            else if (enRecursion.contains(vecino)) { // Si está en la rama actual.
                return true; // Hay ciclo.
            }
        }
        enRecursion.remove(enRecursion.index(actual)); // Se quita de la rama actual.
        return false; // No se encontró ciclo y se retorna false.
    }


    // Metodo para ver si el grafo tiene lazos.
    public boolean tieneLazos() {
        for (int i = 0; i < aristas.getSize(); i++) { // Se miran todas las aristas.
            Arista<E> a = aristas.get(i); // Se guarda la arista.
            if (a.getOrigen().equals(a.getDestino())) { // Si de las aristas que salen del origen alguna tiene como destino el origen.
                return true; // Es que hay una lazo.
            }
        }
        return false; // Si no se retorna false.
    }





