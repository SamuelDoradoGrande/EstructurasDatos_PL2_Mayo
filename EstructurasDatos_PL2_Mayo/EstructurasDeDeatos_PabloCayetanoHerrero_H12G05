//-------------------------------------------------------------------------- Cola (Clase y nodo) -----------------------------------------------------------


public class Cola<E> {

    private NodoCola<E> cabeza;
    private NodoCola<E> pie;
    private int size;

    public Cola() { // El constructor vacía de la Cola.
        cabeza = null;
        pie = null;
        size = 0;
    }

    public void enqueue(E elemento) {
        NodoCola<E> nuevo = new NodoCola<E>(elemento);  // Se crea el elemento.
        if (cabeza == null && pie == null) { // Si no hay ningún elemento, la cabeza y el pie pasan a ser el mismo elemento, el nuevo.
            cabeza = nuevo;
            pie = nuevo;
        }
        else { // Si ya había algún elemento.
            pie.setSiguienteelemento(nuevo); // El siguiente elemento del pie pasa a ser el nuevo elemento.
            pie = nuevo; // El nuevo elemento pasa a llamarse pie, porque toma la posición del que era antes el pie.
        }
        size += 1; // Se amplía en 1 la cola.
    }


    public E dequeue() {

        if (cabeza == null && pie == null) { // Si no hay ningún elemento, no se puede devolver nada.
            return null;
        }
        else { // Si hay datos.
            E dato = cabeza.getDato(); // El dato toma el valor de la cabeza.
            cabeza = cabeza.getSiguienteelemento(); // La cabeza pasa a ser el siguiente elemento, es decir, el elemento que se introdujo después de introducir a la cabeza.

            if (cabeza == null) { // Si la cabeza pasa a ser un elemento inexistente, entonces es que no hay elementos en la cola.
                pie = null; // Entonces el pie pasa a ser ningún elemento.
            }

            size -= 1; // Se disminuye en 1 la cola.
            return dato; // Se retorna el dato eliminado.
        }
    }



    public E peek() {
        if (cabeza == null && pie == null) { // Si no hay elementos, no hay nada qu ver.
            return null;
        }
        return cabeza.getDato(); // Si hay elementos, se ve la cabeza.
    }


    // Metodo para ver si un elemento está en la cola.
    public boolean contains(E elemento) {
        NodoCola<E> actual = cabeza; // Actual se coloca en la cabeza.
        while (actual != null) { // Hasta que actual no exista.
            if (actual.getDato().equals(elemento)) { // Si el actual es el elemento que se busca.
                return true; // Se retorna true.
            }
            actual = actual.getSiguienteelemento(); // Si no lo es, se pasa al siguiente.
        }
        return false; // Si no se ha encontrado se retorna false.
    }


    public int getSize() {
        if (cabeza == null && pie == null) { // Si no hay elementos, el tamaño de la cola es 0.
            return 0;
        }
        else {
            return size; // Si no, se retorna el tamaño que se ha ido regulando al final de cada metodo. .
        }
    }


    // Si la cabeza es null, no existe, y tampoco hay más elementos, entonces está vacía, sino, como mínimo tiene un elemento.
    public boolean isEmpty() {
        return cabeza == null;
    }
}




