package ArbolBinarioDeBúsqueda_y_Grafo.Árbol;

import ArbolBinarioDeBúsqueda_y_Grafo.Lista.Lista;

public class ArbolBinarioDeBusquedaDeEnteros extends ArbolBinarioDeBusqueda<Integer> {


    public int getSuma() { // Metodo para sumar todos los elementos del árbol.
        return sumaRec(getListaPreOrden());
    }

    private int sumaRec(Lista<Integer> lista) { // Metodo paa hacer la suma.
        int suma = 0; // Se inicializa la suma en cero.
        for (int i = 0; i < lista.getSize(); i++) { // Se recorren todos los elementos.
            suma += lista.get(i); // Se van añadiendo a la suma.
        }
        return suma; // Se retorna el valor de la suma total de los elementos dentro del árbol.
    }






    public void sumaOrdenada(int inicio, int fin) { // Metodo para añadir ordenadamente elementos a un árbol.
        for (int i = inicio; i <= fin; i++) { // Se recorren los números.
            add(i); // Se añaden.
        }
    }






    public void sumaAleatoria(int inicio, int fin) { // Metodo para añadir de manera aleatoria elementos a un árbol.
        Lista<Integer> lista = new Lista<>(); // Se crea una lista vacía de enteros.
        for (int i = inicio; i <= fin; i++) {
            lista.add(i); // Se llena la lista en orden.
        }

        while (!lista.isEmpty()) { // Hasta que la lista no esté vacía.
            int indice = (int) (Math.random() * lista.getSize()); // Se trunca la multiplicación entre Math.random (que va desde 0 hasta 1 sin llegar al 1) y el
            // tamaño de la lista, entonces, por ejemolo: 0'33(Math.random) * 5(Tamaño de la lista) = 1'65, entonces lo truncamos y se obtiene el 1, que sería el índice
            // del elemento que se añadiría al árbol.
            int valor = lista.get(indice); // Se busca el elemento en el índice de la lista.
            add(valor); // Se añade al árbol.
            lista.remove(indice); // Se elimina el elemento añadido.
        }
    }
}









