package ArbolBinarioDeBúsqueda_y_Grafo.Grafo;

import ArbolBinarioDeBúsqueda_y_Grafo.Lista.Lista;

public class Vertice<E> {

    private E dato;
    private Lista<Arista<E>> arcosSalida; // Es la arista que sale del vértice.
    private Lista<Arista<E>> arcosEntrada; // Es la arista que llega al vértice.



    public Vertice(E dato) { // Constructor del vértice.
        this.dato = dato;
        arcosSalida = new Lista<>();
        arcosEntrada = new Lista<>();
    }



    // Getter y setter de dato.
    public E getDato() {
        return dato;
    }
    public void setDato(E dato) {
        this.dato = dato;
    }



    // Getters de arista de salida y de entrada.
    public Lista<Arista<E>> getArcosSalida() { return arcosSalida;}
    public Lista<Arista<E>> getArcosEntrada() {
        return arcosEntrada;
    }



    // Metodo add para añadir elementos a las listas de ArcoSalida y ArcoEntrada.
    public void addArcoSalida(Arista<E> arista) {
        arcosSalida.add(arista);
    }
    public void addArcoEntrada(Arista<E> arista) {
        arcosEntrada.add(arista);
    }



    @Override
    public boolean equals(Object obj) {
        if (obj == null || !(obj instanceof Vertice)) { // Si no existe o no es un vértice.
            return false; // Retornamos false.
        }
        Vertice otro = (Vertice) obj; //
        return this.dato.equals(otro.dato); // Se comparan los vértiices.
    }


    @Override
    public String toString() {
        return String.valueOf(dato);
    } // Se pasa el dato a String.
}








