import java.util.ArrayList;
import java.util.Collections;
import java.util.LinkedList;
import java.util.List;
import java.util.Queue;

public class Main {

    public static void main(String[] args) {

        System.out.println("========== PRUEBA 1: NUMEROS EN ORDEN ==========");

        ArbolBinarioDeBusquedaEnteros arbolOrdenado = new ArbolBinarioDeBusquedaEnteros();

        for (int i = 0; i <= 128; i++) {
            arbolOrdenado.add(i);
        }

        probarArbol(arbolOrdenado, 110);


        System.out.println("\n========== PRUEBA 2: NUMEROS ALEATORIOS ==========");

        ArbolBinarioDeBusquedaEnteros arbolAleatorio = new ArbolBinarioDeBusquedaEnteros();

        ArrayList<Integer> numeros = new ArrayList<>();

        for (int i = 0; i <= 128; i++) {
            numeros.add(i);
        }

        Collections.shuffle(numeros);

        for (Integer n : numeros) {
            arbolAleatorio.add(n);
        }

        probarArbol(arbolAleatorio, 110);
    }

    public static void probarArbol(ArbolBinarioDeBusquedaEnteros arbol, int valorBuscado) {

        System.out.println("Suma con getSuma(): " + arbol.getSuma());

        int sumaPreOrden = sumarLista(arbol.getListaPreOrden());
        int sumaPostOrden = sumarLista(arbol.getListaPostOrden());
        int sumaOrdenCentral = sumarLista(arbol.getListaOrdenCentral());

        System.out.println("Suma en preorden: " + sumaPreOrden);
        System.out.println("Suma en postorden: " + sumaPostOrden);
        System.out.println("Suma en orden central: " + sumaOrdenCentral);

        ArbolBinarioDeBusquedaEnteros izquierdo =
                (ArbolBinarioDeBusquedaEnteros) arbol.getSubArbolIzquierda();

        ArbolBinarioDeBusquedaEnteros derecho =
                (ArbolBinarioDeBusquedaEnteros) arbol.getSubArbolDerecha();

        int sumaSubarboles = izquierdo.getSuma() + derecho.getSuma();

        System.out.println("Suma subárbol izquierdo + derecho: " + sumaSubarboles);
        System.out.println("Dato raíz: " + arbol.getRaiz());

        System.out.println("¿Coincide con la suma total? " + (sumaSubarboles == arbol.getSuma()));
        System.out.println("Explicación: los subárboles no incluyen la raíz.");
        System.out.println("Por eso: suma total = raíz + suma izquierda + suma derecha.");

        System.out.println("Altura del árbol: " + arbol.getAltura());
        System.out.println("Grado del árbol: " + arbol.getGrado());

        System.out.println("¿Árbol homogéneo? " + arbol.isArbolHomogeneo());
        System.out.println("¿Árbol completo? " + arbol.isArbolCompleto());
        System.out.println("¿Árbol casi completo? " + arbol.isArbolCasiCompleto());

        ArrayList<Integer> camino = arbol.getCamino(valorBuscado);

        System.out.println("Camino hasta " + valorBuscado + ": " + camino);
        System.out.println("Longitud del camino: " + camino.size());
    }

    public static int sumarLista(ArrayList<Integer> lista) {
        int suma = 0;

        for (Integer n : lista) {
            suma += n;
        }

        return suma;
    }
}

class ArbolBinarioDeBusqueda<T extends Comparable<T>> {

    protected Nodo<T> raiz;

    protected static class Nodo<T> {

        T dato;
        Nodo<T> izquierda;
        Nodo<T> derecha;

        Nodo(T dato) {
            this.dato = dato;
        }
    }

    public void add(T dato) {
        raiz = addRecursivo(raiz, dato);
    }

    private Nodo<T> addRecursivo(Nodo<T> nodo, T dato) {

        if (nodo == null) {
            return new Nodo<>(dato);
        }

        if (dato.compareTo(nodo.dato) < 0) {
            nodo.izquierda = addRecursivo(nodo.izquierda, dato);
        } else if (dato.compareTo(nodo.dato) > 0) {
            nodo.derecha = addRecursivo(nodo.derecha, dato);
        }

        return nodo;
    }

    public T getRaiz() {
        if (raiz == null) {
            return null;
        }

        return raiz.dato;
    }

    public int getAltura() {
        return getAlturaRecursivo(raiz);
    }

    private int getAlturaRecursivo(Nodo<T> nodo) {

        if (nodo == null) {
            return 0;
        }

        int alturaIzquierda = getAlturaRecursivo(nodo.izquierda);
        int alturaDerecha = getAlturaRecursivo(nodo.derecha);

        return 1 + Math.max(alturaIzquierda, alturaDerecha);
    }

    public int getGrado() {
        return getGradoRecursivo(raiz);
    }

    private int getGradoRecursivo(Nodo<T> nodo) {

        if (nodo == null) {
            return 0;
        }

        int hijos = 0;

        if (nodo.izquierda != null) {
            hijos++;
        }

        if (nodo.derecha != null) {
            hijos++;
        }

        int gradoIzquierda = getGradoRecursivo(nodo.izquierda);
        int gradoDerecha = getGradoRecursivo(nodo.derecha);

        return Math.max(hijos, Math.max(gradoIzquierda, gradoDerecha));
    }

    public ArrayList<T> getListaDatosNivel(int nivel) {
        ArrayList<T> lista = new ArrayList<>();
        getListaDatosNivelRecursivo(raiz, nivel, 1, lista);
        return lista;
    }

    private void getListaDatosNivelRecursivo(
            Nodo<T> nodo,
            int nivelBuscado,
            int nivelActual,
            ArrayList<T> lista
    ) {

        if (nodo == null) {
            return;
        }

        if (nivelActual == nivelBuscado) {
            lista.add(nodo.dato);
        }

        getListaDatosNivelRecursivo(nodo.izquierda, nivelBuscado, nivelActual + 1, lista);
        getListaDatosNivelRecursivo(nodo.derecha, nivelBuscado, nivelActual + 1, lista);
    }

    public boolean isArbolHomogeneo() {
        return isArbolHomogeneoRecursivo(raiz);
    }

    private boolean isArbolHomogeneoRecursivo(Nodo<T> nodo) {

        if (nodo == null) {
            return true;
        }

        boolean tieneIzquierda = nodo.izquierda != null;
        boolean tieneDerecha = nodo.derecha != null;

        if (tieneIzquierda != tieneDerecha) {
            return false;
        }

        return isArbolHomogeneoRecursivo(nodo.izquierda)
                && isArbolHomogeneoRecursivo(nodo.derecha);
    }

    public boolean isArbolCompleto() {
        int altura = getAltura();
        int numeroNodos = contarNodos(raiz);

        int nodosArbolCompleto = (int) Math.pow(2, altura) - 1;

        return numeroNodos == nodosArbolCompleto;
    }

    public boolean isArbolCasiCompleto() {

        if (raiz == null) {
            return true;
        }

        Queue<Nodo<T>> cola = new LinkedList<>();
        cola.add(raiz);

        boolean encontradoHueco = false;

        while (!cola.isEmpty()) {

            Nodo<T> actual = cola.poll();

            if (actual.izquierda != null) {

                if (encontradoHueco) {
                    return false;
                }

                cola.add(actual.izquierda);

            } else {
                encontradoHueco = true;
            }

            if (actual.derecha != null) {

                if (encontradoHueco) {
                    return false;
                }

                cola.add(actual.derecha);

            } else {
                encontradoHueco = true;
            }
        }

        return true;
    }

    private int contarNodos(Nodo<T> nodo) {

        if (nodo == null) {
            return 0;
        }

        return 1 + contarNodos(nodo.izquierda) + contarNodos(nodo.derecha);
    }

    public ArbolBinarioDeBusqueda<T> getSubArbolIzquierda() {
        ArbolBinarioDeBusqueda<T> subarbol = new ArbolBinarioDeBusqueda<>();

        if (raiz != null) {
            subarbol.raiz = raiz.izquierda;
        }

        return subarbol;
    }

    public ArbolBinarioDeBusqueda<T> getSubArbolDerecha() {
        ArbolBinarioDeBusqueda<T> subarbol = new ArbolBinarioDeBusqueda<>();

        if (raiz != null) {
            subarbol.raiz = raiz.derecha;
        }

        return subarbol;
    }

    public ArrayList<T> getListaPreOrden() {
        ArrayList<T> lista = new ArrayList<>();
        preOrden(raiz, lista);
        return lista;
    }

    private void preOrden(Nodo<T> nodo, ArrayList<T> lista) {

        if (nodo == null) {
            return;
        }

        lista.add(nodo.dato);
        preOrden(nodo.izquierda, lista);
        preOrden(nodo.derecha, lista);
    }

    public ArrayList<T> getListaPostOrden() {
        ArrayList<T> lista = new ArrayList<>();
        postOrden(raiz, lista);
        return lista;
    }

    private void postOrden(Nodo<T> nodo, ArrayList<T> lista) {

        if (nodo == null) {
            return;
        }

        postOrden(nodo.izquierda, lista);
        postOrden(nodo.derecha, lista);
        lista.add(nodo.dato);
    }

    public ArrayList<T> getListaOrdenCentral() {
        ArrayList<T> lista = new ArrayList<>();
        ordenCentral(raiz, lista);
        return lista;
    }

    private void ordenCentral(Nodo<T> nodo, ArrayList<T> lista) {

        if (nodo == null) {
            return;
        }

        ordenCentral(nodo.izquierda, lista);
        lista.add(nodo.dato);
        ordenCentral(nodo.derecha, lista);
    }

    public ArrayList<T> getCamino(T dato) {
        ArrayList<T> camino = new ArrayList<>();

        Nodo<T> actual = raiz;

        while (actual != null) {

            camino.add(actual.dato);

            int comparacion = dato.compareTo(actual.dato);

            if (comparacion == 0) {
                return camino;
            } else if (comparacion < 0) {
                actual = actual.izquierda;
            } else {
                actual = actual.derecha;
            }
        }

        camino.clear();
        return camino;
    }
}

class ArbolBinarioDeBusquedaEnteros extends ArbolBinarioDeBusqueda<Integer> {

    public int getSuma() {
        return getSumaRecursivo(raiz);
    }

    private int getSumaRecursivo(Nodo<Integer> nodo) {

        if (nodo == null) {
            return 0;
        }

        return nodo.dato
                + getSumaRecursivo(nodo.izquierda)
                + getSumaRecursivo(nodo.derecha);
    }

    @Override
    public ArbolBinarioDeBusqueda<Integer> getSubArbolIzquierda() {
        ArbolBinarioDeBusquedaEnteros subarbol = new ArbolBinarioDeBusquedaEnteros();

        if (raiz != null) {
            subarbol.raiz = raiz.izquierda;
        }

        return subarbol;
    }

    @Override
    public ArbolBinarioDeBusqueda<Integer> getSubArbolDerecha() {
        ArbolBinarioDeBusquedaEnteros subarbol = new ArbolBinarioDeBusquedaEnteros();

        if (raiz != null) {
            subarbol.raiz = raiz.derecha;
        }

        return subarbol;
    }
}














