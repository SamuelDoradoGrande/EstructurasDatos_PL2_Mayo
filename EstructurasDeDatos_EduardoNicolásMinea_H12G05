class Tripleta {

    String sujeto;
    String predicado;
    String objeto;

    public Tripleta(String sujeto, String predicado, String objeto) {
        this.sujeto = sujeto;
        this.predicado = predicado;
        this.objeto = objeto;
    }

    @Override
    public String toString() {
        return "<\"" + sujeto + "\", \"" + predicado + "\", \"" + objeto + "\">";
    }
}

class GrafoRDF {

    private ArrayList<Tripleta> tripletas;
    private HashMap<String, ArrayList<String>> grafo;

    public GrafoRDF() {
        tripletas = new ArrayList<>();
        grafo = new HashMap<>();
    }

    public void addTripleta(String sujeto, String predicado, String objeto) {

        Tripleta t = new Tripleta(sujeto, predicado, objeto);
        tripletas.add(t);

        if (!grafo.containsKey(sujeto)) {
            grafo.put(sujeto, new ArrayList<>());
        }

        if (!grafo.containsKey(objeto)) {
            grafo.put(objeto, new ArrayList<>());
        }

        /*
         * Para calcular caminos mínimos y saber si el grafo es disjunto,
         * tratamos la relación como no dirigida.
         *
         * Es decir:
         * sujeto -- objeto
         */
        grafo.get(sujeto).add(objeto);
        grafo.get(objeto).add(sujeto);
    }

    public void cargarDesdeJSON(String nombreArchivo) {

        try {
            BufferedReader br = new BufferedReader(new FileReader(nombreArchivo));

            String linea;

            String sujeto = "";
            String predicado = "";
            String objeto = "";

            while ((linea = br.readLine()) != null) {

                linea = linea.trim();

                if (linea.startsWith("\"s\"")) {
                    sujeto = obtenerValor(linea);
                } else if (linea.startsWith("\"p\"")) {
                    predicado = obtenerValor(linea);
                } else if (linea.startsWith("\"o\"")) {
                    objeto = obtenerValor(linea);

                    addTripleta(sujeto, predicado, objeto);
                }
            }

            br.close();

        } catch (IOException e) {
            System.out.println("Error leyendo el archivo: " + nombreArchivo);
        }
    }

    private String obtenerValor(String linea) {

        int primeraComilla = linea.indexOf(":");
        String valor = linea.substring(primeraComilla + 1).trim();

        if (valor.endsWith(",")) {
            valor = valor.substring(0, valor.length() - 1);
        }

        valor = valor.trim();

        if (valor.startsWith("\"")) {
            valor = valor.substring(1);
        }

        if (valor.endsWith("\"")) {
            valor = valor.substring(0, valor.length() - 1);
        }

        return valor;
    }

    public void mostrarTripletas() {
        for (Tripleta t : tripletas) {
            System.out.println(t);
        }
    }

    public ArrayList<String> caminoMinimo(String origen, String destino) {

        ArrayList<String> camino = new ArrayList<>();

        if (!grafo.containsKey(origen) || !grafo.containsKey(destino)) {
            return camino;
        }

        Queue<String> cola = new LinkedList<>();
        HashSet<String> visitados = new HashSet<>();
        HashMap<String, String> padre = new HashMap<>();

        cola.add(origen);
        visitados.add(origen);
        padre.put(origen, null);

        while (!cola.isEmpty()) {

            String actual = cola.poll();

            if (actual.equals(destino)) {
                break;
            }

            for (String vecino : grafo.get(actual)) {

                if (!visitados.contains(vecino)) {
                    visitados.add(vecino);
                    padre.put(vecino, actual);
                    cola.add(vecino);
                }
            }
        }

        if (!padre.containsKey(destino)) {
            return camino;
        }

        String actual = destino;

        while (actual != null) {
            camino.add(0, actual);
            actual = padre.get(actual);
        }

        return camino;
    }

    public boolean esDisjunto() {

        if (grafo.isEmpty()) {
            return false;
        }

        HashSet<String> visitados = new HashSet<>();
        Queue<String> cola = new LinkedList<>();

        String primerNodo = grafo.keySet().iterator().next();

        cola.add(primerNodo);
        visitados.add(primerNodo);

        while (!cola.isEmpty()) {

            String actual = cola.poll();

            for (String vecino : grafo.get(actual)) {

                if (!visitados.contains(vecino)) {
                    visitados.add(vecino);
                    cola.add(vecino);
                }
            }
        }

        return visitados.size() != grafo.size();
    }

    public ArrayList<String> getTiposDeNodos() {

        HashSet<String> tipos = new HashSet<>();

        for (String nodo : grafo.keySet()) {

            if (nodo.contains(":")) {
                String tipo = nodo.substring(0, nodo.indexOf(":"));
                tipos.add(tipo);
            } else {
                tipos.add("literal");
            }
        }

        return new ArrayList<>(tipos);
    }

    public ArrayList<String> fisicosNacidosDondeEinstein() {

        ArrayList<String> resultado = new ArrayList<>();

        String ciudadEinstein = buscarObjeto("persona:Albert Einstein", "nace_en");

        for (Tripleta t : tripletas) {

            if (t.predicado.equals("profesion")
                    && t.objeto.equals("fisico")
                    && !t.sujeto.equals("persona:Albert Einstein")) {

                String ciudadPersona = buscarObjeto(t.sujeto, "nace_en");

                if (ciudadPersona.equals(ciudadEinstein)) {
                    resultado.add(t.sujeto);
                }
            }
        }

        return resultado;
    }

    public ArrayList<String> lugaresNacimientoPremiosNobel() {

        HashSet<String> personasConNobel = new HashSet<>();

        for (Tripleta t : tripletas) {

            if (t.predicado.equals("premio") && t.objeto.contains("Nobel")) {
                personasConNobel.add(t.sujeto);
            }
        }

        HashSet<String> lugares = new HashSet<>();

        for (Tripleta t : tripletas) {

            if (personasConNobel.contains(t.sujeto) && t.predicado.equals("nace_en")) {
                lugares.add(t.objeto);
            }
        }

        return new ArrayList<>(lugares);
    }

    private String buscarObjeto(String sujeto, String predicado) {

        for (Tripleta t : tripletas) {

            if (t.sujeto.equals(sujeto) && t.predicado.equals(predicado)) {
                return t.objeto;
            }
        }

        return "";
    }
